<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.echoscrobbler.controller.LoginController"
      styleClass="login-root"
      alignment="CENTER"
      spacing="0"
      fillWidth="true">

    <VBox VBox.vgrow="ALWAYS"/>

    <VBox styleClass="login-card" alignment="CENTER" spacing="0">

        <!-- App name -->
        <Label text="Echo Scrobbler" styleClass="login-wordmark"/>

        <!-- Spacer -->
        <VBox minHeight="32"/>

        <!-- Button -->
        <HBox alignment="CENTER">
            <Button fx:id="loginButton"
                    text="Connect with Last.fm"
                    onAction="#handleLogin"
                    styleClass="login-btn"/>
        </HBox>

        <!-- Status -->
        <Label fx:id="statusLabel" text="" styleClass="login-status"/>

    </VBox>

    <VBox VBox.vgrow="ALWAYS"/>

    <Label text="for linux · built with java" styleClass="login-footer"/>

</VBox>
